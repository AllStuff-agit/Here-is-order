{
  "name": "hereisorder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@10.9.8",
  "scripts": {
    "dev": "wrangler dev",
    "dev:api": "wrangler dev",
    "web:dev": "npm --prefix frontend run dev",
    "web:dev:local": "API_PROXY_URL=http://127.0.0.1:8787 npm --prefix frontend run dev",
    "web:build": "npm --prefix frontend run build",
    "web:start": "npm --prefix frontend run start",
    "web:lint": "npm --prefix frontend run lint",
    "test": "node --test scripts/*.test.mjs && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply hereisorder --local",
    "db:migrate:remote": "wrangler d1 migrations apply hereisorder --remote",
    "db:init": "npm run db:migrate",
    "db:init:remote": "npm run db:migrate:remote",
    "db:seed": "wrangler d1 execute hereisorder --local --file=data/seed_categories_items.sql",
    "db:generate:admin-seed": "node scripts/generate-admin-seed.mjs",
    "db:recover-password": "node scripts/recover-password.mjs",
    "db:manage-smoke-identity": "node scripts/manage-smoke-identity.mjs",
    "db:audit:order-items": "node scripts/audit-order-item-integrity.mjs",
    "deploy:preflight": "node scripts/production-preflight.mjs",
    "deploy:verify-worker": "node scripts/verify-worker-deployment.mjs",
    "test:d1-rest-batch-contract": "node scripts/d1-rest-batch-contract.mjs",
    "db:seed:admin": "npm run db:generate:admin-seed && wrangler d1 execute hereisorder --local --file=data/seed_admin.sql",
    "db:seed:remote": "node scripts/apply-notion-seed.mjs --remote",
    "db:seed:admin:remote": "npm run db:generate:admin-seed && wrangler d1 execute hereisorder --remote --file=data/seed_admin.sql",
    "import:notion": "node scripts/import-notion-export.mjs notion-export",
    "db:bootstrap": "npm run db:migrate && npm run db:seed:admin",
    "db:bootstrap:from-notion": "npm run import:notion && npm run db:migrate && npm run db:seed && npm run db:seed:admin",
    "db:bootstrap:remote": "npm run db:migrate:remote && npm run db:seed:admin:remote"
  },
  "dependencies": {
    "@here-is-order/http-contract": "file:packages/http-contract",
    "hono": "^4.12.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "5.20260708.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10",
    "wrangler": "4.110.0"
  }
}
